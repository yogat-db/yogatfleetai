# npm registry – use the public registry
registry=https://registry.npmjs.org/

# Enable strict engine checks to ensure compatibility
engine-strict=true

# Save exact versions by default (avoid ^ or ~)
save-exact=true

# Disable package-lock.json (optional – use if you prefer yarn or pnpm)
package-lock=false

# Set a timeout for network requests (in milliseconds)
fetch-retries=3
fetch-retry-factor=2
fetch-retry-mintimeout=10000
fetch-retry-maxtimeout=60000

# Disable progress bar in CI environments
progress=false

# Use `npm ci` for deterministic installs
# (no config needed here, but good to know)