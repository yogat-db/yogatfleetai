{
  "compilerOptions": {
    // Enable strict type checking (recommended)
    "strict": true,
    // Allow implicit any (temporarily for older code)
    "noImplicitAny": false,
    // Skip type checking of declaration files (speeds up build)
    "skipLibCheck": true,
    // Use the latest ECMAScript features
    "target": "ES2022",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2022"
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "incremental": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    // Path aliases (matching your project structure)
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ]
    },
    // Include Next.js types
    "types": [
      "node",
      "react",
      "react-dom",
      "next"
    ],
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "out"
  ]
}
